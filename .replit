modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-health"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lojista-rules"

[[workflows.workflow]]
name = "api-health"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -fsS http://localhost:80/api/healthz"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lojista-rules"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/src/validate-lojista-rules.mjs"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
STRIPE_ZONE_BOOST_PRICE_ID = "price_1TT5lsDto2NkIN2Dl9Mztpl3"
STRIPE_BOOST_CAT_1_PRICE_ID = "price_1TTu0FDto2NkIN2DIX5ujhzJ"
STRIPE_BOOST_CAT_2_PRICE_ID = "price_1TTu0FDto2NkIN2DiKTkkUIf"
STRIPE_BOOST_CAT_3_PRICE_ID = "price_1TTu0FDto2NkIN2Da3jfm03l"
STRIPE_BOOST_CAT_4_PRICE_ID = "price_1TTu0GDto2NkIN2DGRVW2D1V"
STRIPE_BOOST_CAT_5_PRICE_ID = "price_1TTu0GDto2NkIN2DtwKAOYIo"
